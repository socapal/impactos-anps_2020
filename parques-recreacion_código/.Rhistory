rm (list=ls())
paquetes=c("dplyr","tidyr", "ggplot2",  "sf",
"readxl", "pastecs", "modelsummary")
sapply(paquetes,
function (x){
if(! x %in% rownames(installed.packages()))
install.packages(x)
require(x, character.only=T)
})
